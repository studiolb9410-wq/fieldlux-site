{
  "name": "fieldlux-site",
  "version": "1.0.0",
  "private": true,
  "description": "FieldLux landing page — static site with prebuilt Tailwind CSS.",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./assets/tailwind.css --minify",
    "watch": "tailwindcss -i ./src/input.css -o ./assets/tailwind.css --watch",
    "dev": "npm run watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3"
  }
}
